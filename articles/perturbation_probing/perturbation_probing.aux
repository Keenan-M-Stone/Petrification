\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Fixed-point drift $x^*(\varepsilon )$ for the sine perturbation $p(x) = \qopname  \relax o{sin}(\omega x)$ with $\omega = 10$, $a = 3.7$. Blue: numerical root-finding; red dashed: IFT linear approximation (Theorem\nobreakspace  {}\ref  {thm:drift}). \textbf  {Left}: non-trivial fixed point $x^*_1 \approx 0.730$. \textbf  {Right}: trivial fixed point $x^*_0 = 0$. The two drift curves have opposite slopes, consistent with Corollary\nobreakspace  {}\ref  {cor:opposite}. }}{2}{figure.1}\protected@file@percent }
\newlabel{fig:drift}{{1}{2}{Fixed-point drift $x^*(\eps )$ for the sine perturbation $p(x) = \sin (\omega x)$ with $\omega = 10$, $a = 3.7$. Blue: numerical root-finding; red dashed: IFT linear approximation (Theorem~\ref {thm:drift}). \textbf {Left}: non-trivial fixed point $x^*_1 \approx 0.730$. \textbf {Right}: trivial fixed point $x^*_0 = 0$. The two drift curves have opposite slopes, consistent with Corollary~\ref {cor:opposite}}{figure.1}{}}
