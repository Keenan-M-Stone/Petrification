\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Fixed-point drift $\Delta x^*_1$ at the non-trivial fixed point vs.\ sinusoidal frequency $\omega $, for $\varepsilon = 0.03$, $a = 3.7$. Blue curve: IFT prediction\nobreakspace  {}\textup  {\hbox {\mathsurround \z@ \normalfont  (\ignorespaces \ref  {eq:ift}\unskip \@@italiccorr )}}; red dots: numerical Brent root-finding at spot frequencies; green vertical lines: null frequencies $\omega _k = k\pi /x^*_1$. The drift vanishes exactly at the null frequencies. }}{3}{figure.3}\protected@file@percent }
\newlabel{fig:null}{{3}{3}{Fixed-point drift $\Delta x^*_1$ at the non-trivial fixed point vs.\ sinusoidal frequency $\omega $, for $\eps = 0.03$, $a = 3.7$. Blue curve: IFT prediction~\eqref {eq:ift}; red dots: numerical Brent root-finding at spot frequencies; green vertical lines: null frequencies $\omega _k = k\pi /x^*_1$. The drift vanishes exactly at the null frequencies}{figure.3}{}}
